# Copy to deploy/langfuse/.env and replace all CHANGEME secrets before production use.
# Quick dev setup: from repo root run `make langfuse-dev-setup` (headless init).
# Docs: https://langfuse.com/self-hosting/administration/headless-initialization
#
# Generate secrets:
#   openssl rand -hex 32      # ENCRYPTION_KEY
#   openssl rand -base64 32   # NEXTAUTH_SECRET, SALT

NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=CHANGEME-nextauth-secret

DATABASE_URL=postgresql://postgres:CHANGEME-postgres@postgres:5432/postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME-postgres
POSTGRES_DB=postgres

SALT=CHANGEME-salt
ENCRYPTION_KEY=CHANGEME-64-hex-chars-from-openssl-rand-hex-32

CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=CHANGEME-clickhouse

REDIS_AUTH=CHANGEME-redis

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGEME-minio

LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=CHANGEME-minio
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=CHANGEME-minio

# Headless initialization (creates org + project + user + API keys on first start).
# Do not quote values in docker compose. Re-run only on empty DB (see make dev-langfuse-fresh).
LANGFUSE_INIT_ORG_ID=egregore
LANGFUSE_INIT_ORG_NAME=Egregore
LANGFUSE_INIT_PROJECT_ID=egregore-dev
LANGFUSE_INIT_PROJECT_NAME=egregore-dev
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-egregore-dev-local
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-egregore-dev-local
LANGFUSE_INIT_USER_EMAIL=dev@egregore.local
LANGFUSE_INIT_USER_NAME=Dev Admin
LANGFUSE_INIT_USER_PASSWORD=egregore-dev
