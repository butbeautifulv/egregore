# syntax=docker/dockerfile:1
# cxado/egregore-api — FastAPI ingress/CRUD service. No langchain/langgraph/
# deepagents/litellm in this image; see docs/MICROSERVICES_SPLIT_PLAN.md.
# Build from egregore repo root: docker build -f deploy/Dockerfile.api .
#
# Builder: deps + uv sync. Runtime: fresh slim, OS upgraded, perl-base removed (SCA surface).

FROM python:3.13-slim@sha256:bffeb7bd6a85767587059c6ba23e1e9122078e3aa3fa836099171b9bb5a9bb00 AS builder
ENV DEBIAN_FRONTEND=noninteractive
ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy
WORKDIR /app
COPY --from=ghcr.io/astral-sh/uv:0.11.12@sha256:027318b213a7804ecd085ea7efdcdc4d44fa202c6e676c86ce86c0206d38f65c /uv /usr/local/bin/uv

# Layer 1: lockfiles + contracts' own source (egregore-api depends on
# egregore-contracts as an editable ../contracts path dependency, so uv
# needs contracts' src/ present to install it even before api's own source
# is copied) — cached until either package's deps or contracts' src change.
COPY backend/contracts/pyproject.toml backend/contracts/uv.lock backend/contracts/README.md ./contracts/
COPY backend/contracts/src ./contracts/src
COPY backend/api/pyproject.toml backend/api/uv.lock backend/api/README.md ./api/
WORKDIR /app/api
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-install-project

# Layer 2: api's own source — only reinstalls api's local wheel, not all deps.
COPY backend/api/src ./src
COPY backend/agents /app/agents
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev

FROM python:3.13-slim@sha256:bffeb7bd6a85767587059c6ba23e1e9122078e3aa3fa836099171b9bb5a9bb00 AS runtime
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV STAGE=prod
ENV USE_MEMORY_FALLBACK=false
ENV CONTROL_MODE=daemon
ENV AGENTS_ROOT=../agents
ENV UV_CACHE_DIR=/tmp/uv-cache
WORKDIR /app/api

RUN apt-get update \
 && apt-get upgrade -y \
 && apt-get purge -y --allow-remove-essential \
      perl-base gzip login util-linux mount \
 && rm -rf /var/lib/apt/lists/* \
 && groupadd --gid 10001 app \
 && useradd --uid 10001 --gid app --home-dir /app --no-create-home app

COPY --from=builder --chown=app:app /app/contracts/src /app/contracts/src
COPY --from=builder --chown=app:app /app/api /app/api
COPY --from=builder --chown=app:app /app/agents /app/agents

USER 10001
ENV PATH="/app/api/.venv/bin:$PATH"

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8080/health', timeout=3)" || exit 1

ENTRYPOINT ["egregore"]
CMD ["serve", "--host", "0.0.0.0", "--port", "8080"]
