# Corp / offline build — Nexus base + PyPI, no BuildKit cache mounts (Kaniko-compatible).
# egregore-agent-runtime image (K8s Job executor + optional worker daemon rollback).
# Build from egregore repo root: docker build -f deploy/Dockerfile.corp.agent-runtime .
ARG NEXUS_REGISTRY=nexus.svo.aero:8345
ARG NEXUS_PYPI_HOST=nexus.svo.aero:8443
ARG NEXUS_PYPI_REPO=srsips-pypi
ARG NEXUS_USER
ARG NEXUS_PASSWORD

FROM ${NEXUS_REGISTRY}/library/python:3.13-slim
WORKDIR /app
RUN pip install --no-cache-dir uv

ENV UV_INDEX_URL=https://${NEXUS_USER}:${NEXUS_PASSWORD}@${NEXUS_PYPI_HOST}/repository/${NEXUS_PYPI_REPO}/simple

COPY backend/agent-runtime/pyproject.toml backend/agent-runtime/uv.lock backend/agent-runtime/README.md ./agent-runtime/
WORKDIR /app/agent-runtime
RUN uv sync --frozen --no-dev --no-install-project

COPY backend/agent-runtime/src ./src
COPY backend/agents /app/agents
RUN uv sync --frozen --no-dev

ENV PYTHONUNBUFFERED=1
ENV STAGE=prod
ENV USE_MEMORY_FALLBACK=false
ENV AGENTS_ROOT=../agents

RUN groupadd -g 10001 app && useradd -u 10001 -g app -m app && chown -R app:app /app
USER 10001

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
  CMD ["uv", "run", "egregore", "status"]

# Default CMD for worker-monolith rollback; K8s Jobs override args to run-sandboxed-job.
CMD ["uv", "run", "egregore", "worker", "--daemon", "--idle-timeout", "0"]
