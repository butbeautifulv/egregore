# GAIA benchmark profile (R&D / regression — not default SOC mode)
STAGE=dev
USE_MEMORY_FALLBACK=true
EGREGORE_ONE_TOOL_PER_TURN=true
TASK_HINTS_ENABLED=true
TRACE_CRITIC_ENABLED=true
TRACE_CRITIC_EVERY_N_STEPS=2
CONTEXT_SUMMARY_MAX_MESSAGES=30
OBS_EVAL_BACKEND=langfuse
OBS_JUDGE_BACKEND=langfuse
HITL_AUTO_APPROVE_THRESHOLD=low
DEFAULT_JOB_RECURSION_LIMIT=40
WEB_SEARCH_PROVIDER=duckduckgo
RUN_ATTACHMENTS_DIR=/tmp/egregore-gaia-attachments
REASONING_MODEL=openai/o3-mini
CONTEXT_SUMMARY_ENABLED=true
TRACE_CRITIC_RERUN_MAX=2
