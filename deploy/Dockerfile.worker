# syntax=docker/dockerfile:1
# cxado/egregore-worker — agent-execution runtime (LangChain/LangGraph today,
# swappable later without touching the api image). See
# docs/MICROSERVICES_SPLIT_PLAN.md.
# Build from egregore repo root: docker build -f deploy/Dockerfile.worker .
FROM python:3.13-slim AS base
WORKDIR /app
COPY --from=ghcr.io/astral-sh/uv:0.11.12 /uv /usr/local/bin/uv

# Layer 1: lockfiles + contracts' own source (egregore-worker depends on
# egregore-contracts as an editable ../contracts path dependency, so uv
# needs contracts' src/ present to install it even before worker's own
# source is copied) — cached until either package's deps or contracts' src
# change.
COPY backend/contracts/pyproject.toml backend/contracts/uv.lock backend/contracts/README.md ./contracts/
COPY backend/contracts/src ./contracts/src
COPY backend/worker/pyproject.toml backend/worker/uv.lock backend/worker/README.md ./worker/
WORKDIR /app/worker
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-install-project

# Layer 2: worker's own source — only reinstalls worker's local wheel, not
# all deps.
COPY backend/worker/src ./src
COPY backend/agents /app/agents
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev

ENV PYTHONUNBUFFERED=1
ENV STAGE=prod
ENV USE_MEMORY_FALLBACK=false
ENV AGENTS_ROOT=../agents

RUN groupadd -g 10001 app && useradd -u 10001 -g app -m app && chown -R app:app /app
USER 10001

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
  CMD ["uv", "run", "egregore", "status"]

CMD ["uv", "run", "egregore", "worker", "--daemon", "--idle-timeout", "0"]
