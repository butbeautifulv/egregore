# LLM API keys (first non-empty is used)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# DeepSeek — keep in deploy/.secrets/egregore-local.env (never commit)
# DEEPSEEK_API_KEY=

# LLM configuration
LLM_PROVIDER=litellm
LLM_MODEL=deepseek/deepseek-v4-flash
# Optional — omit for provider-default routing; set for OpenRouter / local vLLM etc.
# LLM_BASE_URL=https://openrouter.ai/api/v1
# Local vLLM example (model id from GET /v1/models):
# LLM_MODEL=openai/Kbenkhaled/Qwen3.5-27B-NVFP4
# LLM_BASE_URL=http://10.8.185.185:11611/v1
LLM_TEMPERATURE=0.1
LLM_REQUEST_TIMEOUT=120
MANUAL_INVESTIGATION_ASYNC=true
PLANNER_FALLBACK_PERSONAS=consultant

# Observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Deprecated: use LANGFUSE_PUBLIC_KEY instead
# LANGFUSE_API_KEY=
LANGFUSE_HOST=http://localhost:3001
# Optional alias (Langfuse skills / SDK convention)
# LANGFUSE_BASE_URL=http://localhost:3001
# LLM-as-a-Judge: run `./scripts/langfuse-setup-llm-judge.sh` after Langfuse is up
# LANGFUSE_LLM_PROVIDER=egregore-vllm
# LANGFUSE_JUDGE_SAMPLING=0.25

# OpenTelemetry (optional — requires make dev-obs for Tempo on :4317)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# UI (operator console CORS)
UI_CORS_ORIGINS=http://localhost:3000

# Operator-only agent streaming (dev/local; disabled in prod)
# Dev live chat: STREAM_AGENT_OUTPUT=true, STREAM_AGENT_TOKEN_STREAMING=true, EGRESS_BATCH_SECONDS=0
STREAM_AGENT_OUTPUT=false
STREAM_AGENT_TOOLS=true
STREAM_AGENT_TOKEN_STREAMING=false

# Control plane: daemon required now that api/worker are separate packages
# (inprocess only works in the transitional single-venv dev setup)
CONTROL_MODE=daemon
# Deprecated: use Langfuse platform eval jobs (scripts/langfuse-setup-llm-judge.sh)
CRITIC_USE_LLM_JUDGE=false
COORDINATOR_CHAT_NARRATIVE=false
COORDINATOR_LLM_NARRATIVE=false
TRACE_CRITIC_ENABLED=true

# Runtime
STAGE=dev
USE_MEMORY_FALLBACK=false
WORKER_IDLE_TIMEOUT=0
WORKER_REPLICAS=2
PERSISTENCE_CONNECTOR=auto
JOB_STORE_CONNECTOR=auto
AGENTS_ROOT=../agents  # sibling backend/agents/, since CWD is this package's own dir
BUS_SIGNING_KEY=cys-agi-bus-key

# Security
HITL_AUTO_APPROVE_THRESHOLD=low
MAX_TOOL_CALLS_PER_MINUTE=30
TRUST_SCORE_THRESHOLD=0.5

# Keycloak OIDC (Ingress API + Tool Gateway) — disabled by default
AUTH_ENABLED=0
RBAC_ENABLED=0
KEYCLOAK_ISSUER=
KEYCLOAK_AUDIENCE=
KEYCLOAK_CLIENT_ID=egregore-api
RBAC_ROLE_INGRESS=egregore-ingress
RBAC_ROLE_OPERATOR=egregore-operator
RBAC_ROLE_GATEWAY=egregore-gateway
RBAC_ROLE_READER=egregore-reader
# Static Bearer for worker → gateway when AUTH_ENABLED=1 (client-credentials in phase 2)
GATEWAY_ACCESS_TOKEN=

# UI OIDC BFF (Next.js route handlers; disabled unless issuer/client are set)
NEXT_PUBLIC_OIDC_ISSUER=
OIDC_CLIENT_ID=egregore-ui
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
NEXT_PUBLIC_ALLOW_LOCAL_TOKEN=0

# OpenFGA ReBAC — off by default; start with compose profile `fga`
AUTHZ_MODE=off
OPENFGA_API_URL=http://localhost:8088
OPENFGA_STORE_ID=
OPENFGA_MODEL_ID=
OPENFGA_API_TOKEN=
WORKSPACE_STORE_CONNECTOR=auto

# Redis (rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0

# Postgres (LangGraph checkpointer + store)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=egregore

# Kafka / Redpanda (event bus — optional; Redis queue remains fallback)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
USE_KAFKA=false
STRICT_REDIS_QUEUE=false
BUS_MAX_JOBS_PER_ENGAGEMENT=20

# MCP Tool Gateway (PEP for sandbox tool calls; :8092 — Veil Graph API uses :8090)
TOOL_GATEWAY_URL=http://localhost:8092
USE_TOOL_GATEWAY=true

# Veil knowledge MCP (graph + playbooks) — http://localhost:8091/mcp when stack is up
VEIL_MCP_URL=http://localhost:8091/mcp
VEIL_MCP_ENABLED=true
# VEIL_MCP_TIMEOUT=30
# Required for CTI/playbook enrichment — load agents/skills/veil-knowledge at runtime

# Denial of Wallet (per worker job)
JOB_COST_PER_1K_TOKENS_USD=0.003
MAX_HIGH_RISK_TOOL_CHAIN_DEPTH=3
DEFAULT_JOB_RECURSION_LIMIT=25

# Secure RAG (Qdrant optional; in-memory store when USE_QDRANT=false)
QDRANT_URL=http://localhost:6333
USE_QDRANT=false
USE_REAL_EMBEDDINGS=false
RAG_MAX_CHUNKS=5

# SIEM adapter: mock | http (legacy — prefer SIEM_MCP_* below)
SIEM_ADAPTER=mock
SIEM_BASE_URL=

# MaxPatrol SIEM MCP (incidents, events) — http://localhost:8094/mcp when stack is up
SIEM_MCP_URL=http://localhost:8094/mcp
SIEM_MCP_ENABLED=false
# SIEM_MCP_TIMEOUT=60

# Nessus / Tenable MCP (vulnerability inventory) — http://localhost:8095/mcp
NESSUS_MCP_URL=http://localhost:8095/mcp
NESSUS_MCP_ENABLED=false
# NESSUS_MCP_TIMEOUT=180

# Control plane status store: auto | memory | postgres
STATUS_STORE_CONNECTOR=auto

# Operator UI (egregore-ui) CORS origins, comma-separated
UI_CORS_ORIGINS=http://localhost:3000

# Sandbox connector: local | k8s
SANDBOX_CONNECTOR=local
K8S_NAMESPACE=cys-agi
K8S_WORKER_IMAGE=cys-agi-worker:latest
