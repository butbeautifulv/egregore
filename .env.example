# LLM API keys (first non-empty is used)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# LLM configuration
LLM_PROVIDER=litellm
LLM_MODEL=anthropic/claude-sonnet-4
# Optional — omit for provider-default routing; set for OpenRouter etc.
# LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0.1

# Observability (optional)
LANGFUSE_API_KEY=
LANGFUSE_HOST=http://localhost:3000

# Runtime
STAGE=dev
USE_MEMORY_FALLBACK=false
AGENTS_ROOT=agents

# Security
HITL_AUTO_APPROVE_THRESHOLD=low
MAX_TOOL_CALLS_PER_MINUTE=30
TRUST_SCORE_THRESHOLD=0.5

# Kafka / Redpanda event bus (Phase 1)
USE_KAFKA=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis (rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0

# Postgres (LangGraph checkpointer + store)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=cys_agi
