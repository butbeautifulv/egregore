# LLM API keys (first non-empty is used)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# LLM configuration
LLM_PROVIDER=litellm
LLM_MODEL=anthropic/claude-sonnet-4
# Optional — omit for provider-default routing; set for OpenRouter etc.
# LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0.1

# Observability (optional)
LANGFUSE_API_KEY=
LANGFUSE_HOST=http://localhost:3000

# Runtime
STAGE=dev
USE_MEMORY_FALLBACK=false
PERSISTENCE_CONNECTOR=auto
JOB_STORE_CONNECTOR=auto
AGENTS_ROOT=agents
BUS_SIGNING_KEY=cys-agi-bus-key

# Security
HITL_AUTO_APPROVE_THRESHOLD=low
MAX_TOOL_CALLS_PER_MINUTE=30
TRUST_SCORE_THRESHOLD=0.5

# Keycloak OIDC (Ingress API + Tool Gateway) — disabled by default
AUTH_ENABLED=0
RBAC_ENABLED=0
KEYCLOAK_ISSUER=
KEYCLOAK_AUDIENCE=
KEYCLOAK_CLIENT_ID=egregore-api
RBAC_ROLE_INGRESS=egregore-ingress
RBAC_ROLE_OPERATOR=egregore-operator
RBAC_ROLE_GATEWAY=egregore-gateway
RBAC_ROLE_READER=egregore-reader
# Static Bearer for worker → gateway when AUTH_ENABLED=1 (client-credentials in phase 2)
GATEWAY_ACCESS_TOKEN=

# Redis (rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0

# Postgres (LangGraph checkpointer + store)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=cys_agi

# Kafka / Redpanda (event bus — optional; Redis queue remains fallback)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
USE_KAFKA=false

# MCP Tool Gateway (PEP for sandbox tool calls)
TOOL_GATEWAY_URL=http://localhost:8090
USE_TOOL_GATEWAY=false

# Denial of Wallet (per worker job)
JOB_COST_PER_1K_TOKENS_USD=0.003
MAX_HIGH_RISK_TOOL_CHAIN_DEPTH=3
DEFAULT_JOB_RECURSION_LIMIT=25

# Secure RAG (Qdrant optional; in-memory store when USE_QDRANT=false)
QDRANT_URL=http://localhost:6333
USE_QDRANT=false
USE_REAL_EMBEDDINGS=false
RAG_MAX_CHUNKS=5

# SIEM adapter: mock | http
SIEM_ADAPTER=mock
SIEM_BASE_URL=

# Control plane status store: auto | memory | postgres
STATUS_STORE_CONNECTOR=auto

# Sandbox connector: local | k8s
SANDBOX_CONNECTOR=local
K8S_NAMESPACE=cys-agi
K8S_WORKER_IMAGE=cys-agi-worker:latest
