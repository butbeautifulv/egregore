OPENAI_API_KEY=example_api_key
ANTHROPIC_API_KEY=example_api_key
GEMINI_API_KEY=example_api_key
OPENROUTER_API_KEY=example_api_key

LLM_PROVIDER=litellm
LLM_MODEL=anthropic/claude-sonnet-4
# Optional — omit for provider-default routing; set for OpenRouter etc.
# LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0.1

LANGFUSE_API_KEY=example_api_key
LANGFUSE_HOST=https://localhost:3000

# dev/test/prod
STAGE=dev
USE_MEMORY_FALLBACK=false
AGENTS_ROOT=agents
HITL_AUTO_APPROVE_THRESHOLD=low
MAX_TOOL_CALLS_PER_MINUTE=30
TRUST_SCORE_THRESHOLD=0.5

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres